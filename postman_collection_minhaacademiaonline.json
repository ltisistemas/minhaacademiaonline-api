                                "sign-up"
                            ]
                        }
                    }
                },
                {
                    "name": "Sign In",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "let data = {};",
                                    "try { data = pm.response.json(); } catch (e) {}",
                                    "if (data.access_token) pm.collectionVariables.set('token', data.access_token);",
                                    "if (data.subdomain) pm.collectionVariables.set('subdomain', data.subdomain);",
                                    "if (data.tenantId) pm.collectionVariables.set('tenantId', data.tenantId);"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"subdomain\": \"{{subdomain}}\",\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/v1/sign-in",
                            "host": [
