                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"selectedPlan\": \"{{selectedPlanId}}\",\n  \"fee\": 129.90,\n  \"legalName\": \"Academia Exemplo LTDA\",\n  \"tradeName\": \"Academia Exemplo\",\n  \"nif\": \"123456789\",\n  \"userName\": \"admin\",\n  \"userEmail\": \"admin@academia.com\",\n  \"userPassword\": \"123456\"\n}"
